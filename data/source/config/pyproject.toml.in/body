[build-system]
requires = ["setuptools >= 74.1.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "${library_name}-python"
version = "@VERSION@"
description = "Python bindings for ${library_name}"
maintainers = [
    { name = "Joachim Metz", email = "joachim.metz@gmail.com" },
]
license = "LGPL-3.0-or-later"
license-files = ["COPYING", "COPYING.LESSER"]
readme = {file = "README", content-type = "text/markdown"}
classifiers = [
    "Development Status :: ${python_module_development_status}",
    "Programming Language :: Python",
]
requires-python = ">=3.10"

[project.urls]
Documentation = "https://github.com/libyal/${library_name}/wiki/Home"
Homepage = "https://github.com/libyal/${library_name}"
Repository = "https://github.com/libyal/${library_name}"

[tool.setuptools]
py-modules = ["_build"]

[[tool.setuptools.ext-modules]]
name = "${python_module_name}"
sources = []

[tool.setuptools.cmdclass]
build_ext = "_build.custom_build_ext"
sdist = "_build.custom_sdist"
