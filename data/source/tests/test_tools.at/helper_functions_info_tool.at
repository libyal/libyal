
dnl Runs exeinfo with input.
dnl Arguments:
dnl   test_input
m4_define([RUN_TEST_EXEINFO_WITH_INPUT],
  [m4_define([sanitized_test_input],
    [m4_translit([$$1], [[],[],[]"'`\], [______])])

  AT_SETUP(exeinfo with input: 'sanitized_test_input')

  AT_SKIP_IF(
    [test -n "$${SKIP_TOOLS_TESTS}" || test -n "$${SKIP_TOOLS_END_TO_END_TESTS}"])

  AT_SKIP_IF([test -z "$${GZIP_COMMAND}"])
  AT_SKIP_IF([test -z "$${SED}"])
  AT_SKIP_IF([test -z "$${ZCAT}"])

  TEST_FILE=`ath_fn_resolve_test_file "$$abs_srcdir/input/$$1"`

  AT_CHECK(
    [FILENAME=`basename "$${TEST_FILE}"`
    TEST_SET=`dirname "$${TEST_FILE}"`
    TEST_SET=`basename "$${TEST_SET}"`
    OUTPUT_FILE="$${FILENAME}.log"

    ath_fn_run_exetools_binary exeinfo "$${TEST_FILE}" > "$${OUTPUT_FILE}"
    STATUS=$$?

    if test $${STATUS} -eq 0; then
      # Strip header with version.
      $${SED} -i'~' '1,2d' "$${OUTPUT_FILE}"

      EXPECTED_RESULTS="$$abs_srcdir/input/.exeinfo/$${TEST_SET}/$${FILENAME}.gz"
      if test -f "$${EXPECTED_RESULTS}"; then
        # zcat on Mac OS requires the input from stdin.
        $${ZCAT} < "$${EXPECTED_RESULTS}" | diff "$${OUTPUT_FILE}" -;
        STATUS=$$?
      else
        $${GZIP_COMMAND} "$${OUTPUT_FILE}"
	mkdir -p "$${EXPECTED_RESULTS}"
        mv "$${OUTPUT_FILE}.gz" "$${EXPECTED_RESULTS}"
      fi
    fi
    exit $$STATUS])

  AT_CLEANUP])

dnl Runs exeinfo with options and input.
dnl Arguments:
dnl   option_set
dnl   test_options
dnl   test_input
m4_define([RUN_TEST_EXEINFO_WITH_OPTIONS_AND_INPUT],
  [m4_define([sanitized_test_input],
    [m4_translit([$$3], [[],[],[]"'`\], [______])])

  AT_SETUP(exeinfo with options: '$$2' and input: 'sanitized_test_input')

  AT_SKIP_IF(
    [test -n "$${SKIP_TOOLS_TESTS}" || test -n "$${SKIP_TOOLS_END_TO_END_TESTS}"])

  AT_SKIP_IF([test -z "$${GZIP_COMMAND}"])
  AT_SKIP_IF([test -z "$${SED}"])
  AT_SKIP_IF([test -z "$${ZCAT}"])

  TEST_FILE=`ath_fn_resolve_test_file "$$abs_srcdir/input/$$3"`

  AT_CHECK(
    [FILENAME=`basename "$${TEST_FILE}"`
    TEST_SET=`dirname "$${TEST_FILE}"`
    TEST_SET=`basename "$${TEST_SET}"`
    OPTION_SET="$$1"
    OUTPUT_FILE="$${OUTPUT_FILE}-$${OPTION_SET}.log"

    ath_fn_run_exetools_binary exeinfo "$${TEST_FILE}" > "$${OUTPUT_FILE}"
    STATUS=$$?

    if test $${STATUS} -eq 0; then
      # Strip header with version.
      $${SED} -i'~' '1,2d' "$${OUTPUT_FILE}"

      EXPECTED_RESULTS="$$abs_srcdir/input/.exeinfo/$${TEST_SET}/$${FILENAME}.gz"
      if test -f "$${EXPECTED_RESULTS}"; then
        # zcat on Mac OS requires the input from stdin.
        $${ZCAT} < "$${EXPECTED_RESULTS}" | diff "$${OUTPUT_FILE}" -;
        STATUS=$$?
      else
        $${GZIP_COMMAND} "$${OUTPUT_FILE}"
        mv "$${OUTPUT_FILE}.gz" "$${EXPECTED_RESULTS}"
      fi
    fi
    exit $$STATUS])

  AT_CLEANUP])

dnl Runs exeinfo tests.
dnl Arguments:
dnl   test_inputs
m4_define([RUN_TEST_EXEINFO],
  [m4_foreach_w(
    [test_input],
    [$$1],
    [m4_define([option_set], m4_normalize(get_test_result_value([test_input], 1)))
    m4_define([test_options], m4_normalize(get_test_result_value([test_input], 2)))
    m4_define([test_file], m4_normalize(get_test_result_value([test_input], 3)))

    m4_ifblank(
      test_options,
      [RUN_TEST_EXEINFO_WITH_INPUT([test_file])],
      [RUN_TEST_EXEINFO_WITH_OPTIONS_AND_INPUT(
        [option_set],
       	[test_options],
       	[test_file])]
    )]
  )]
)
