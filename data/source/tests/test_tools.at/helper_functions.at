
AT_TEST_HELPER_FN(
  [run_${library_name_suffix}tools_binary],
  [path arguments],
  [Resolves and runs the ${library_name_suffix}tools binary],
  [if test -x "$$abs_top_builddir/${library_name_suffix}tools/$$[]1"; then
    BINARY="$$abs_top_builddir/${library_name_suffix}tools/$$[]1"
  elif test -x "$$abs_top_builddir/${library_name_suffix}tools/$$[]1.exe"; then
    # Prevent wine debug messages failing the test.
    export WINEDEBUG=-all

    BINARY="$$abs_top_builddir/${library_name_suffix}tools/$$[]1.exe"
  else
    echo "Missing binary: $$[]1"
    exit 127
  fi
  shift

  $$BINARY $$[]*
  ])
